# 🛡️ cicd/Agent: Deployment Credentials
# Copy this to .env and keep it secret!

# FTP Connection
AGENT_FTP_HOST=ftp.yourdomain.com
AGENT_FTP_USER=your_ftp_username
AGENT_FTP_PASS=your_ftp_password
AGENT_FTP_PATH=public_html

# Webhook Bridge
AGENT_HOOK_URL=https://yourdomain.com/core/deploy_hook.php
AGENT_WEBHOOK_SECRET=YOUR_SUPER_SECRET_HMAC_TOKEN_HERE

# Package Configuration
AGENT_ZIP_NAME=deploy_package.zip
AGENT_INCLUDE_PATHS=index.php,src,public,config.json
